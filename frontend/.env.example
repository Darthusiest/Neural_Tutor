# Dev: leave empty to use Vite proxy to Flask (same origin /api).
# Production: set to your Render backend URL, e.g. https://your-api.onrender.com
VITE_API_BASE_URL=

# Mutating API calls use CSRF automatically (see src/api/client.js): GET /api/auth/csrf
# + X-CSRFToken on POST/PUT/PATCH/DELETE. No extra env vars needed.
