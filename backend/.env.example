# Copy to `.env` in this directory (or export in your shell). Flask loads via python-dotenv if you use it.
# See `app/config.py` for every variable and defaults.

# --- Core ---
FLASK_SECRET_KEY=change-me-in-production
DATABASE_URL=
# Comma-separated allowed SPA origins for CORS. Non-production also auto-adds the
# localhost ↔ 127.0.0.1 twin so either URL works with VITE_API_BASE_URL.
FRONTEND_ORIGIN=http://127.0.0.1:5173
# Comma-separated. These accounts get User.is_admin on register and each successful login.
ADMIN_EMAILS=pajouhes@usc.edu

# --- OpenAI (primary Course Answer + optional OpenAI boost fallback) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SEC=60
# Primary Course Answer LLM call (seconds); boost uses BOOST_TIMEOUT_SEC separately.
PRIMARY_LLM_TIMEOUT_SEC=8
# Sampling 0–2 (lower = more deterministic).
OPENAI_TEMPERATURE_COURSE_ANSWER=0.4
OPENAI_TEMPERATURE_BOOST=0.45
OPENAI_TEMPERATURE_DEFAULT=0.5

# --- Gemini (Boosted Explanation secondary path) ---
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SEC=60
# Deferred Boosted Explanation HTTP timeout (per provider attempt; 2s is often too short).
BOOST_TIMEOUT_SEC=25
GEMINI_TEMPERATURE_BOOST=0.4
GEMINI_MAX_OUTPUT_TOKENS=2048

# --- Admin Gemini critic (LLM-as-judge on stored eval runs; uses GEMINI_API_KEY) ---
# CRITIC_MODEL=gemini-2.5-flash
# CRITIC_TEMPERATURE=0.1
# CRITIC_TIMEOUT_SEC=120
# CRITIC_MAX_OUTPUT_TOKENS=4096
# CRITIC_USE_RESPONSE_SCHEMA=1
# Max characters of stored CHATBOT_ANSWER sent in the critic prompt (avoid context overflow).
# CRITIC_ANSWER_CHAR_CAP=14000
# CRITIC_PROMPT_VERSION=v2
# PASS if overall score >= threshold:
# CRITIC_PASS_THRESHOLD=0.68
# Comma-separated effective modes when POST body omits "modes" (default chat,compare,summary — skips quiz).
# CRITIC_CASE_MODES=chat,compare,summary
# Optional batch cap (estimated tokens; 0 = unlimited):
# CRITIC_MAX_TOKENS_PER_BATCH=0
# Free AI Studio tier is often ~5 RPM / low RPD — each critic case can trigger multiple API calls
# (MIME attempts + retries). Use billing for large suites, or set spacing, e.g.:
# CRITIC_MIN_INTERVAL_BETWEEN_REQUESTS_SEC=13
# CRITIC_INTER_CASE_DELAY_SEC=1
# CRITIC_HTTP_MAX_RETRIES=12

# --- Retrieval / chat pipeline ---
# Max chunks requested for grounding on the first retrieval pass (chat + structured pipeline).
CHAT_RETRIEVAL_TOP_K=5
# When answer validation hard-fails, retry with top_k + this extra budget.
PIPELINE_RETRY_TOP_K_EXTRA=6
# Confidence below this nudges boost / diagnostics (see boost_triggers).
CONFIDENCE_THRESHOLD=0.35
# v2 single-lecture summary cap (lexical rank within lecture).
SUMMARY_MAX_CHUNKS=48

# --- Structured pipeline feature flags ---
STRUCTURED_PIPELINE_ENABLED=1
PIPELINE_RETRIEVAL_RETRY_ENABLED=1
# Skip the extra retrieval retry if the pipeline has already run longer than this (seconds).
PIPELINE_RETRY_WALL_CLOCK_BUDGET_SEC=3.5
PRIMARY_COURSE_ANSWER_OPENAI=1
ENTITY_EVIDENCE_SCORING_ENABLED=1

# --- Optional: lexical scoring overrides (JSON merges into defaults) ---
# RETRIEVAL_FIELD_WEIGHTS_JSON={"topic":3.0,"keywords":2.5}
# RETRIEVAL_PHRASE_FIELD_WEIGHT_JSON={"topic":1.0,"keywords":0.95}
